// schema.prisma (переработанная с атомарными записями CEU и часов)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT     // обычный пользователь
  REVIEWER    // проверяет CEU и супервизию
  ADMIN       // полный доступ
}

enum RecordStatus {
  UNCONFIRMED
  CONFIRMED
  REJECTED
  SPENT
}

enum CEUCategory {
  ETHICS
  CULTURAL_DIVERSITY
  SUPERVISION
  GENERAL
}

enum PracticeLevel {
  INSTRUCTOR
  CURATOR
  SUPERVISOR

  PRACTICE      // старый формат обычной практики, продолжаем учитывать
  SUPERVISION   // менторские часы для супервизоров, продолжаем использовать

  IMPLEMENTING  // новый подтип практики
  PROGRAMMING   // новый подтип практики
}

enum TargetLevel {
  INSTRUCTOR
  CURATOR
  SUPERVISOR
}

enum CycleType {
  CERTIFICATION
  RENEWAL
}

enum CycleStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum PaymentType {
  DOCUMENT_REVIEW
  EXAM_ACCESS
  REGISTRATION
  RENEWAL
  FULL_PACKAGE
}

enum ExamStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
}

enum ConsentDocumentType {
  TRANSBORDER_PD_TRANSFER
}

enum ConsentSource {
  REGISTRATION_MODAL
  LEGACY_MODAL
}

enum ConsentEmailStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationType {
  CEU
  SUPERVISION
  MENTORSHIP
  DOCUMENT
  EXAM
  PAYMENT
  NEW_USER
}

model User {
  id                       String   @id @default(cuid())
  email                    String   @unique
  password                 String
  fullName                 String
  fullNameLatin            String?     // ФИО на латинице для международных реестров/сертификатов

  phone                    String?
  birthDate                DateTime?
  country                  String?
  city                     String?
  avatarUrl                String?
  isEmailConfirmed         Boolean  @default(false)
  role                     Role     @default(STUDENT)
  bio                      String?
  isProfileVisible         Boolean  @default(true)

  certificates             Certificate[]
  ceuRecords               CEURecord[]
  supervisionRecords       SupervisionRecord[]
  groups                   UserGroup[]
  uploadedFiles            UploadedFile[]

  reviewedCEUEntries       CEUEntry[]        @relation("ReviewedCEUEntry")
  reviewedSupervisionHours SupervisionHour[] @relation("ReviewedSupervisionHour")
  confirmedCertificates    Certificate[]     @relation("CertificateConfirmedBy")

  documentReviewRequests   DocumentReviewRequest[]

  examApplication          ExamApplication?
  payments                 Payment[]
  notifications            Notification[]
  consents                 UserConsent[]

  createdAt                DateTime @default(now())
  lastActiveAt             DateTime?

  targetLevel              TargetLevel? // Целевой уровень специализации (лесенка, если NULL)
  targetLockRank           Int?        // ранг, при котором цель была выбрана

  cycles                   CertificationCycle[]
}

model UserConsent {
  id                String              @id @default(cuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  documentType      ConsentDocumentType
  documentVersion   String
  documentTextHash  String

  acceptedItems     Json

  source            ConsentSource
  emailAtMoment     String

  ip                String?
  userAgent         String?
  clientId          String?
  requestId         String?

  consentedAt       DateTime            @default(now())

  emailStatus       ConsentEmailStatus  @default(PENDING)
  emailSentAt       DateTime?
  emailError        String?

  createdAt         DateTime            @default(now())

  @@unique([userId, documentType, documentVersion])
  @@index([userId])
  @@index([documentType, documentVersion])
  @@index([consentedAt])
}

model CertificationCycle {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetLevel     TargetLevel
  type            CycleType   @default(CERTIFICATION)
  status          CycleStatus @default(ACTIVE)

  startedAt       DateTime    @default(now())
  endedAt         DateTime?
  abandonedReason String?

  // records live inside cycle
  ceuRecords        CEURecord[]
  supervisionRecords SupervisionRecord[]

  // certificate knows the cycle (1 cycle -> 0..1 certificate)
  certificate     Certificate?

  requirementsSnapshot Json?
  modifiersSnapshot Json?

  @@index([userId])
  @@index([userId, status])
}

model SupervisionDistribution {
  id                     String   @id @default(cuid())

  cycleId                String   @unique

  directIndividual       Float    @default(0)
  directGroup            Float    @default(0)
  nonObservingIndividual Float    @default(0)
  nonObservingGroup      Float    @default(0)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model CustomCity {
  id                       String   @id @default(cuid())
  countryCode              String
  name                     String                    // нормализованное имя города по-русски
  createdAt                DateTime @default(now())
  createdById              String?                    // опционально: кто добавил

  @@unique([countryCode, name])
}

enum PaymentProvider {
  TOCHKA
}

model Payment {
  id                    String           @id @default(cuid())
  userId                String
  user                  User             @relation(fields: [userId], references: [id])

  type                  PaymentType
  targetLevel           TargetLevel?
  provider              PaymentProvider  @default(TOCHKA)
  status                PaymentStatus    @default(UNPAID)

  externalPaymentId     String?
  externalCustomerCode  String?
  paymentUrl            String?

  providerStatus        String?
  providerPayload       Json?

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  confirmedAt           DateTime?
  comment               String?

  webhookEvents         PaymentWebhookEvent[]

  @@unique([provider, externalPaymentId])
  @@unique([provider, externalCustomerCode])

  @@index([userId])
  @@index([status])
  @@index([type, targetLevel])
}

model PaymentWebhookEvent {
  id                   String           @id @default(cuid())

  provider             PaymentProvider
  eventType            String?
  externalEventId      String?
  externalPaymentId    String?
  externalCustomerCode String?

  paymentId            String?
  payment              Payment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  isValidSignature     Boolean          @default(false)
  isProcessed          Boolean          @default(false)
  processingError      String?

  statusBefore         PaymentStatus?
  statusAfter          PaymentStatus?

  rawBody              String
  payloadJson          Json?

  receivedAt           DateTime         @default(now())
  processedAt          DateTime?

  @@index([provider, externalPaymentId])
  @@index([provider, externalCustomerCode])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  message   String
  link      String?
  createdAt DateTime         @default(now())

  isRead    Boolean          @default(false)
}

model ExamApplication {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    ExamStatus @default(NOT_SUBMITTED)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Certificate {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])

  groupId       String
  group         Group          @relation(fields: [groupId], references: [id])

  fileId        String         @unique
  file          UploadedFile   @relation(fields: [fileId], references: [id])

  issuedAt      DateTime
  expiresAt     DateTime

  isRenewal     Boolean        @default(false)

  previousId    String?        @unique
  previous      Certificate?   @relation("CertificateHistory", fields: [previousId], references: [id])
  next          Certificate?   @relation("CertificateHistory")

  confirmedById String?
  confirmedBy   User?          @relation("CertificateConfirmedBy", fields: [confirmedById], references: [id])

  comment       String?
  number        String
  title         String
  createdAt     DateTime       @default(now())

  cycleId String? @unique
  cycle   CertificationCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
}

model CEURecord {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  fileId     String?
  eventName  String
  eventDate  DateTime
  createdAt  DateTime @default(now())

  entries    CEUEntry[]

  cycleId    String?
  cycle      CertificationCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([cycleId])
}

model CEUEntry {
  id         String   @id @default(cuid())
  recordId   String
  record     CEURecord @relation(fields: [recordId], references: [id])

  category   CEUCategory
  value      Float
  status     RecordStatus @default(UNCONFIRMED)

  reviewerId String?
  reviewer   User?    @relation("ReviewedCEUEntry", fields: [reviewerId], references: [id])
  reviewedAt DateTime?
  rejectedReason String?
}

model SupervisionRecord {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  fileId     String?
  createdAt  DateTime @default(now())

  hours      SupervisionHour[]

  cycleId    String?
  cycle      CertificationCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([cycleId])
}

model SupervisionHour {
  id         String   @id @default(cuid())
  recordId   String
  record     SupervisionRecord @relation(fields: [recordId], references: [id])

  type       PracticeLevel
  value      Float
  status     RecordStatus @default(UNCONFIRMED)

  reviewerId String?
  reviewer   User?    @relation("ReviewedSupervisionHour", fields: [reviewerId], references: [id])
  reviewedAt DateTime?
  rejectedReason String?
}

model Group {
  id           String       @id @default(cuid())
  name         String       @unique
  rank         Int          @default(0)
  users        UserGroup[]
  certificates Certificate[]
  createdAt    DateTime     @default(now())
}

model UserGroup {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  createdAt DateTime @default(now())
}

model DocumentReviewRequest {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])

  status         RecordStatus  @default(UNCONFIRMED)
  paid           Boolean       @default(false)
  reviewerEmail  String?
  submittedAt    DateTime      @default(now())
  reviewedAt     DateTime?
  comment        String?

  documents      UploadedFile[]
}

model UploadedFile {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  fileId      String   @unique
  name        String
  certificate Certificate?
  mimeType    String
  type        String?
  comment     String?
  createdAt   DateTime @default(now())

  requestId String?
  request       DocumentReviewRequest? @relation(fields: [requestId], references: [id])
}
