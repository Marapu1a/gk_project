{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/utils/certificateLifecycle.test.js dist/lib/monitoringState.test.js dist/domain/ceu/duplicateFile.test.js dist/domain/ceu/reviewPolicy.test.js dist/domain/supervision/legacyPracticeRequest.test.js",
    "start": "node dist/server.js",
    "migrate:deploy": "prisma migrate deploy",
    "backfill:ceu-file-hashes": "node dist/scripts/backfillCeuFileHashes.js",
    "backfill:ceu-file-hashes:build": "npm run build && npm run backfill:ceu-file-hashes",
    "legacy:supervision:dry-run": "node dist/scripts/normalizeLegacySupervisionRequests.js",
    "legacy:supervision:apply": "node dist/scripts/normalizeLegacySupervisionRequests.js --apply",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.2.0",
    "@prisma/client": "^6.8.2",
    "@sentry/node": "^10.66.0",
    "@types/bcrypt": "^5.0.2",
    "axios": "^1.9.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.3.3",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.13.7",
    "mailtrap": "^4.4.0",
    "nodemailer": "^7.0.13",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^6.8.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
